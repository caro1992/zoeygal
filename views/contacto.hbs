<h1 class="text-center"> Contacto </h1>


<div class="container mt-5">
    <h3>¿Tenés preguntas? Escribinos</h3>
    <div class="row">
        <div class="col">
            <label for="name" class="form-label">Nombre*</label>
            <input type="text" id="name" class="form-control" aria-label="nombre">
        </div>
        <div class="col">
            <label for="surname" class="form-label">Apellido*</label>
            <input type="text" id="surname" class="form-control" aria-label="Last name">
        </div>
    </div>
  
    <div class="row mt-3">
        <div class="col">
            <label for="email" class="form-label">Email*</label>
            <input type="email" class="form-control" id="email">
        </div>
    </div>

    <div class="row mt-3 mb-3">
        <div class="col">
            <label for="validationTextarea" id="mensaje" class="form-label">Mensaje*</label>
    <textarea class="form-control" id="mensaje" required></textarea>
        </div>
    </div>

      <div class="d-grid mt-4 mb-5">
        <button type="submit"  class="btn btn-dark rounded-pill ps-5 pe-5">Enviar</button>
  </div>

